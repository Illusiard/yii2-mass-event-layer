{
  "name": "illusiard/yii2-mass-event-layer",
  "description": "Zero-config mass event layer for Yii2: intercepts bulk DB operations and emits unified events (sync/async-ready) with nested transaction safety.",
  "type": "yii2-extension",
  "license": "MIT",
  "keywords": [
    "yii2",
    "events",
    "audit",
    "mass-operations",
    "bulk",
    "transaction",
    "savepoint"
  ],
  "require": {
    "php": ">=8.1",
    "yiisoft/yii2": "^2.0.0",
    "ext-json": "*",
    "ext-ctype": "*",
    "yiisoft/yii2-queue": "^2.3"
  },
  "autoload": {
    "psr-4": {
      "illusiard\\massEvents\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "illusiard\\massEvents\\tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "extra": {
    "bootstrap": "illusiard\\massEvents\\components\\Bootstrap"
  },
  "suggest": {
    "yiisoft/yii2-queue": "Enables asynchronous publishing through Yii2 Queue (auto-detected by the layer)."
  },
  "require-dev": {
    "illusiard/yii2-testkit": "^0.1.0",
    "phpunit/phpunit": "^10.5"
  }
}
